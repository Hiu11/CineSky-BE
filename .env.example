PORT=5000

# SAU KHI CLONE:
# - Dùng MongoDB local: giữ nguyên dòng dưới, nhưng phải bật MongoDB trước
# - Dùng MongoDB Atlas: đổi dòng dưới thành link Atlas của bạn
# Ví dụ Atlas: mongodb+srv://username:password@cluster.mongodb.net/movie-web-pro
MONGO_URI=mongodb://localhost:27017/movie-web-pro

# SAU KHI CLONE: đổi thành chuỗi bất kỳ, dài và khó đoán
# Ví dụ: JWT_SECRET=cinesky_access_secret_123456
JWT_SECRET=your_access_token_secret

JWT_EXPIRES_IN=1d

# SAU KHI CLONE: đổi thành chuỗi khác JWT_SECRET
# Ví dụ: JWT_REFRESH_SECRET=cinesky_refresh_secret_123456
JWT_REFRESH_SECRET=your_refresh_token_secret

JWT_REFRESH_EXPIRES_IN=7d

SEED_ON_START=false

FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:5000

# Google OAuth redirect URI to add in Google Cloud Console:
# http://localhost:5000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback

# Facebook OAuth redirect URI:
# http://localhost:5000/api/v1/auth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:5000/api/v1/auth/facebook/callback

# Optional: dùng cho nút đồng bộ metadata phim trong Admin
TMDB_API_KEY=
